# ─── Supabase (required for all dynamic data) ───────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Resend (required for newsletter emails + contact form notifications) ────────
# 1. Create account at https://resend.com
# 2. Verify your domain (Domains → Add Domain)
# 3. Create an API key (API Keys → Create API Key)
# 4. Set VITE_RESEND_FROM_EMAIL to a verified sender address on your domain
# Contact form submissions are forwarded to info@estilolatinodance.com
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
VITE_RESEND_FROM_EMAIL=Estilo Latino <noreply@estilolatinodance.com>
